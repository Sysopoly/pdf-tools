---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Sysopoly PDF Tools</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <header class="bg-white shadow relative z-10 w-full">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <a href="/" class="text-xl font-bold text-gray-900">Sysopoly <span class="text-blue-600">PDF</span></a>
        </div>
        <nav class="flex gap-4">
          <a href="/" class="text-gray-600 hover:text-gray-900 font-medium">Tools</a>
          <a href="/about" class="text-gray-600 hover:text-gray-900 font-medium">About & Privacy</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col pt-8">
      <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-4">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-100 border-t border-gray-200 mt-auto py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-500">
        <p>Created by Sysopoly. This tool is 100% free, runs entirely in your browser, and values your privacy.</p>
        <p class="mt-2">
          <a href="/about" class="text-blue-600 hover:underline">Learn more about how it works</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
